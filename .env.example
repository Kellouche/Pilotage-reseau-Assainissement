# SWMM Platform POC - configuration locale

# Application
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=5002
API_RELOAD=true
LEGACY_FLASK_PORT=5000
SQL_ECHO=False

# Source GeoPackage locale
# Remplacer par le chemin local de la donnée source.
GPKG_PATH=D:\IA Water Data Analysis\Assainissement\Assainissement_Ville.gpkg

# PostgreSQL/PostGIS cible
# Si PostgreSQL n'est pas disponible, l'application bascule actuellement vers SQLite.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swmm_platform
DB_USER=postgres
DB_PASSWORD=

# Redis / Celery
REDIS_HOST=localhost
REDIS_PORT=6379

# Mobile / Web
MOBILE_API_BASE_URL=http://127.0.0.1:5001
EXPO_WEB_PORT=19006
